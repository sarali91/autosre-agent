# ========================================
# AutoSRE Enterprise .gitignore
# ========================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# macOS specific system files (Crucial for M3 Mac)
.DS_Store
.AppleDouble
.LSOverride
Icon

# Thumbnails and hidden files
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.Trashes

# IDE / Code Editors
.vscode/
.idea/
*.swp
*.swo

# Virtual Environments
.venv/
venv/
env/
ENV/

# Testing & Coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
